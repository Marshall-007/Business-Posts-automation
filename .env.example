# Copy to .env and fill in the values you have. Every platform is optional.
# See SETUP.md for how to obtain each credential.

# Content generation (recommended)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Facebook Page
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram (Instagram Login flow — token starts with "IGAA")
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
# Optional: app secret, lets a short-lived token auto-upgrade to 60-day
INSTAGRAM_APP_SECRET=


# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# X (Twitter)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
