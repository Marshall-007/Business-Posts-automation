# Copy to .env and fill in the values you have. Every platform is optional.
# See SETUP.md for how to obtain each credential.

# Content generation (recommended)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Facebook Page
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram (Instagram Login flow — token starts with "IGAA")
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
# Optional: app secret, lets a short-lived token auto-upgrade to 60-day
INSTAGRAM_APP_SECRET=

# TikTok (Content Posting API). The refresh token is the durable secret;
# TIKTOK_ACCESS_TOKEN is auto-refreshed from it every 4h. Keep privacy on
# SELF_ONLY until your app passes TikTok review, then PUBLIC_TO_EVERYONE.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# X (Twitter)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
